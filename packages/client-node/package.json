{
  "name": "@sikuligo/sikuligo",
  "version": "0.1.4",
  "description": "SikuliGO Node.js client",
  "keywords": [
    "sikuli",
    "sikulix",
    "sikuligo",
    "automation",
    "testing",
    "recorder",
    "replay",
    "visual",
    "desktop",
    "gui",
    "screen",
    "image",
    "pattern",
    "scripting",
    "e2e",
    "blackbox",
    "bot",
    "rpa",
    "robot framework"
  ],
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "init-examples": "dist/src/init-examples.js",
    "sikuligo": "dist/src/cli.js",
    "sikuligo-doctor": "dist/src/doctor.js",
    "sikuligo-init-examples": "dist/src/init-examples.js"
  },
  "files": [
    "dist",
    "generated",
    "examples",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:binaries": "bash ../../scripts/clients/build-node-binaries.sh",
    "build": "bash ../../scripts/clients/generate-node-stubs.sh && tsc -p tsconfig.json",
    "prepack": "npm run clean && npm run build",
    "doctor": "node dist/src/doctor.js",
    "examples:init": "node dist/src/init-examples.js",
    "example:workflow:auto": "node examples/workflow-auto-launch.mjs",
    "example:workflow:connect": "node examples/workflow-connect.mjs",
    "example:find": "node examples/find.mjs",
    "example:click": "node examples/click.mjs",
    "example:ocr": "node examples/ocr.mjs",
    "example:input": "node examples/input.mjs",
    "example:app": "node examples/app.mjs",
    "example:user-flow": "node examples/user-flow.mjs"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@grpc/proto-loader": "^0.8.0"
  },
  "optionalDependencies": {
    "@sikuligo/bin-darwin-arm64": "0.1.4",
    "@sikuligo/bin-darwin-x64": "0.1.4",
    "@sikuligo/bin-linux-x64": "0.1.4",
    "@sikuligo/bin-win32-x64": "0.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "grpc-tools": "^1.13.0",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
